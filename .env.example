JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=CMPI

# ── Optional: Confluence Integration ─────────────────────────────────────────
# Required for Confluence tools (leave unset to disable Confluence integration)
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
# CONFLUENCE_EMAIL=your-email@example.com
# CONFLUENCE_API_TOKEN=your-api-token

# Space keys to restrict search to (comma-separated, optional but recommended)
# CONFLUENCE_SPACE_KEYS=SPACE1,SPACE2

# Search and budget limits
# CONFLUENCE_MAX_SEARCH_RESULTS=10
# CONFLUENCE_MAX_PAGES_TO_READ=5
# CONFLUENCE_MAX_PAGE_CHARS=12000

# Set to false to disable Confluence even if credentials are configured
# CONFLUENCE_ENABLED=true

# Label boosts (pages with these labels score higher for relevance)
# CONFLUENCE_LABEL_BOOSTS=requirements,prd,technical-design,architecture,user-guide,release-notes

# Labels that indicate deprecated/stale pages (penalized in relevance scoring)
# CONFLUENCE_EXCLUDE_LABELS=deprecated,archive,draft

# Title keywords that suggest high-authority documentation
# CONFLUENCE_TITLE_BOOST_TERMS=requirement,prd,design,spec,architecture,flow

# ── Optional: Delivery Intelligence — Pattern Memory ──────────────────────────
# Set to true to enable local project pattern memory (disabled by default)
# DELIVERY_PATTERN_MEMORY_ENABLED=false

# Custom path for the pattern memory file (relative to repo root)
# DELIVERY_PATTERN_MEMORY_FILE=.mcp-project-patterns.json

# ── Security and Performance Settings ────────────────────────────────────────

# HTTP timeouts and retries
# MCP_HTTP_TIMEOUT_MS=15000
# MCP_HTTP_MAX_RETRIES=3
# MCP_HTTP_INITIAL_BACKOFF_MS=500
# MCP_HTTP_MAX_BACKOFF_MS=10000
# MCP_RATE_LIMIT_RESPECT_RETRY_AFTER=true

# In-memory caching
# MCP_CACHE_ENABLED=true
# MCP_CACHE_TTL_JIRA_SECONDS=300
# MCP_CACHE_TTL_CONFLUENCE_SECONDS=600
# MCP_CACHE_MAX_ITEMS=500

# Concurrency limits
# MCP_MAX_CONCURRENT_JIRA_REQUESTS=3
# MCP_MAX_CONCURRENT_CONFLUENCE_REQUESTS=3
# MCP_MAX_CONCURRENT_GITHUB_REQUESTS=2

# Output budget limits
# MCP_MAX_OUTPUT_CHARS=60000
# MCP_MAX_SECTION_CHARS=12000
# MCP_MAX_DIFF_CHARS=50000
# MCP_MAX_CONFLUENCE_CHARS=30000

# Logging and debug
# MCP_LOG_LEVEL=info
# MCP_LOG_REDACT_SECRETS=true
# MCP_DEBUG=false
# MCP_PERFORMANCE_LOGGING=false
